<Container version="2">
  <Name>Dragonwilds Dedicated Server</Name>
  <Repository>ich777/steamcmd-server:dragonwilds</Repository>
  <Registry>https://hub.docker.com/r/ich777/steamcmd-server/</Registry>
  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/79530-support-ich777-gameserver-dockers/</Support>
  <Project>https://dragonwilds.runescape.com/</Project>
  <Overview>Dedicated server for RuneScape: Dragonwilds (0.11 Dowdun Reach). Automatically updates via SteamCMD.</Overview>
  <Category>GameServers:</Category>
  <Icon>https://raw.githubusercontent.com/Crimson7806/unraid-templates/main/icons/runescape-dragonwilds.png</Icon>

  <Config Name="GAME_ID" Target="GAME_ID" Default="4019830" Type="Variable" Display="always" Required="true"/>
  
  <Config Name="Owner ID" Target="OWNER_ID" Default="" Type="Variable" Display="always" Required="true" Mask="false">YOUR_COPIED_ID_HERE</Config>

  <Config Name="Game Port" Target="7777" Default="7777" Mode="udp" Type="Port" Display="always" Required="true"/>
  <Config Name="Query Port" Target="27015" Default="27015" Mode="udp" Type="Port" Display="always" Required="true"/>

  <Config Name="Server Name" Target="SERVER_NAME" Default="Dragonwilds Server" Type="Variable" Display="always"/>
  <Config Name="Max Players" Target="MAX_PLAYERS" Default="6" Type="Variable" Display="always"/>
  <Config Name="Admin Password" Target="ADMIN_PASSWORD" Default="" Type="Variable" Display="always" Mask="true"/>
</Container>
